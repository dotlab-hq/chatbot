# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# Better Auth
BETTER_AUTH_SECRET=****
BETTER_AUTH_URL=http://localhost:3000

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# AWS S3 configuration for file uploads
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=****
AWS_SECRET_ACCESS_KEY=****
S3_BUCKET=your-bucket-name
# S3_PUBLIC_URL=**** # optional, override the public URL (useful for CloudFront or custom domains)
# AWS_ENDPOINT=**** # optional, for S3-compatible services like MinIO

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# Redis (ioredis) — used for IP rate limiting and resumable streams
REDIS_URL=redis://localhost:6379

# MongoDB Atlas — persistent memory for the chatbot
# Get a free cluster at https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/chatbot_memory?retryWrites=true&w=majority
# MONGODB_DB_NAME=chatbot_memory # optional, defaults to chatbot_memory

# OpenSERP — self-hosted or cloud web search (https://openserp.org)
OPENSERP_API_KEY=****
# OPENSERP_BASE_URL=**** # optional, override for self-hosted (e.g., http://localhost:7000)
